{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++ 生成活动文件",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "-Wextra",
                "${file}",
                "-o",
                "${workspaceFolder}/output/try/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "OUTPUT_DIR": "${workspaceFolder}/output/try"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "编译到 output/try 目录",
            "dependsOn": [
                "创建输出目录"
            ]
        },
        {
            "type": "shell",
            "label": "创建输出目录",
            "command": "mkdir",
            "args": [
                "-p",
                "${workspaceFolder}/output/try"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc 生成活动文件",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}